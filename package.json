{
  "name": "sanjang",
  "version": "0.3.0",
  "description": "Local dev environment manager for vibe coders",
  "type": "module",
  "bin": {
    "sanjang": "./bin/sanjang.js"
  },
  "scripts": {
    "start": "node bin/sanjang.js",
    "test": "node --experimental-transform-types --test test/**/*.test.ts bin/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npx @biomejs/biome check lib/ test/ bin/"
  },
  "dependencies": {
    "express": "^4.19.2",
    "simple-git": "^3.27.0",
    "ws": "^8.18.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paul-sherpas/sanjang.git"
  },
  "keywords": [
    "dev-tools",
    "worktree",
    "vibe-coding",
    "local-dev"
  ],
  "files": [
    "bin/",
    "lib/",
    "dashboard/",
    "templates/"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
